# Hedgeye Bot — Environment Variables
# Copy this file to .env and fill in your values
# NEVER share this file or commit it to GitHub

# ── iCloud Email (IMAP) ────────────────────────────────────────
ICLOUD_EMAIL=Bogacki20@icloud.com
# Generate an app-specific password at: https://appleid.apple.com
# Go to: Sign-In & Security → App-Specific Passwords → Generate
ICLOUD_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# ── Anthropic (Claude API) ─────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Pushover (push notifications) ─────────────────────────────
# Sign up at: https://pushover.net
# PUSHOVER_TOKEN: your application's API token (create one under "Your Applications")
# PUSHOVER_USER:  your user key (shown on the main dashboard after login)
PUSHOVER_TOKEN=azGDORePK8gMaC0QOYAMyEEuzJnyUi
PUSHOVER_USER=uQiRzpo4DXghDmr9QzzfQu

# ── Optional Settings ──────────────────────────────────────────
# How often to scrape portal (seconds). Default: 900 = 15 minutes
SCRAPE_INTERVAL_SECONDS=900
# How often to check email (seconds). Default: 900 = 15 minutes
EMAIL_CHECK_INTERVAL=900
# Hour (ET) to send morning brief. Default: 7 = 7:00am
MORNING_BRIEF_HOUR=7
# Database file path (Railway provides /data as persistent volume)
DB_PATH=/data/hedgeye.db
